<!-- MARQUEE -->
<div class="marq">
  <div class="marq-track">
    <span>Slow Burning</span><span>No Heavy Metals</span><span>No Pesticides</span><span>Ultra Thin</span><span>100% Organic</span><span>Tobacco Free</span>
    <span>Slow Burning</span><span>No Heavy Metals</span><span>No Pesticides</span><span>Ultra Thin</span><span>100% Organic</span><span>Tobacco Free</span>
  </div>
</div>

<!-- MANIFESTO -->
<section class="manifesto">
  <div class="wrap reveal">
    <div class="rule"></div>
    <p>Most cones are an afterthought. <b>Ours is the entire point.</b> Cleaner paper, a slower burn, and a shape that opens right every time.</p>
    <div class="rule b"></div>
  </div>
</section>

<!-- THE CONES -->
<section class="cones cream" id="cones">
  <div class="wrap">
    <div class="cgrid">
      <div class="cimg reveal"><span class="fr"></span><img src="data:image/jpeg;base64," alt="A spread of Roll Baby Roll pre-rolled cones, papers and tips"></div>
      <div class="reveal">
        <div class="ey"><span class="ln"></span><span class="lab">The cones</span></div>
        <div class="sec-head" style="margin-bottom:30px"><h2 style="font-size:clamp(34px,4.4vw,56px)">The cone, perfected.</h2></div>
        <div class="spec"><span class="sn">01</span><div><h3>Organic unbleached paper</h3><p>Pure natural fibre. No chlorine, no chalk, no additives, no aftertaste.</p></div></div>
        <div class="spec"><span class="sn">02</span><div><h3>Slow, even burn</h3><p>Pressed for a steady draw that burns low and slow, corner to corner.</p></div></div>
        <div class="spec"><span class="sn">03</span><div><h3>Firm spiral tip</h3><p>A real tip in every cone. Open, fill, twist, go. No fumbling, no fuss.</p></div></div>
        <div class="spec"><span class="sn">04</span><div><h3>Ultra thin</h3><p>Less paper, less interference. You taste what is inside, not the wrap.</p></div></div>
      </div>
    </div>
  </div>
</section>

<!-- PACKAGING -->
<section class="pkg" id="packaging">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="ey" style="justify-content:center"><span class="ln"></span><span class="lab">The packaging</span><span class="ln"></span></div>
      <h2>Built for the shelf. Made for the table.</h2>
      <p>Two finishes, one obsessive standard. A resealable slide box that protects every cone and looks the part wherever it lands.</p>
    </div>
    <div class="pkg-wrap reveal">
      <span class="corner c1"></span><span class="corner c2"></span><span class="corner c3"></span><span class="corner c4"></span>
      <img src="data:image/jpeg;base64," alt="Roll Baby Roll packaging in Natural Kraft and Midnight finishes">
    </div>
    <div class="fin2 reveal">
      <div class="f"><span class="sw k"></span><div><h3>Natural Kraft</h3><p>Raw, unbleached, honest. Warm craft board and forest green, the original.</p></div></div>
      <div class="f"><span class="sw m"></span><div><h3>Midnight</h3><p>Matte charcoal, low-key, premium. The finish for the late roll.</p></div></div>
    </div>
  </div>
</section>

<!-- ORGANIC -->
<section class="org cream" id="organic">
  <div class="wrap">
    <div class="sec-head reveal" style="margin-bottom:46px">
      <div class="ey"><span class="ln"></span><span class="lab">Why organic</span></div>
      <h2>Clean, all the way down.</h2>
    </div>
    <div class="ogrid reveal">
      <div class="ocell"><span class="on">01</span><h3>100% organic</h3><p>Natural materials end to end, the way it should always have been.</p></div>
      <div class="ocell"><span class="on">02</span><h3>No nasties</h3><p>No heavy metals and no pesticides. Nothing you would not want in a roll.</p></div>
      <div class="ocell"><span class="on">03</span><h3>Ultra thin</h3><p>Barely there paper, so flavour comes through and burn stays even.</p></div>
      <div class="ocell"><span class="on">04</span><h3>Sustainable</h3><p>Responsibly sourced fibre and packaging that respects where it lands.</p></div>
    </div>
  </div>
</section>

<!-- GALLERY -->
<section class="gal" id="gallery">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="ey"><span class="ln"></span><span class="lab">The look</span></div>
      <h2>Made to be seen.</h2>
    </div>
    <div class="gmosaic reveal">
      <div class="gm big"><img src="data:image/jpeg;base64," alt="Roll Baby Roll packaging, two finishes"><div class="cap">Signature packaging · two finishes</div></div>
      <div class="gm"><img src="data:image/jpeg;base64," alt="Organic cones styled set"><div class="cap">Organic cones · styled set</div></div>
      <div class="gm"><img src="data:image/jpeg;base64," alt="Cones, papers and tips spread"><div class="cap">The full spread · cones, papers, tips</div></div>
    </div>
  </div>
</section>

<!-- STANDARD -->
<section class="std cream" id="standard">
  <div class="wrap">
    <div class="sec-head reveal" style="margin-bottom:36px">
      <div class="ey"><span class="ln"></span><span class="lab">Our standard</span></div>
      <h2>Every box, held to this.</h2>
      <p>No shortcuts and no asterisks. This is what Roll Baby Roll means, on every single cone.</p>
    </div>
    <div class="clist reveal">
      <div class="citem"><span class="ck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></span><div><h3>Organic, unbleached paper</h3><p>Pure natural fibre. No chlorine, no chalk, no additives.</p></div></div>
      <div class="citem"><span class="ck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></span><div><h3>Slow, even burn</h3><p>A steady draw that burns low and slow, corner to corner.</p></div></div>
      <div class="citem"><span class="ck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></span><div><h3>Ultra thin</h3><p>Less paper, less interference. You taste what is inside.</p></div></div>
      <div class="citem"><span class="ck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></span><div><h3>No heavy metals, no pesticides</h3><p>Tested to stay true to the organic promise on the box.</p></div></div>
      <div class="citem"><span class="ck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></span><div><h3>Firm spiral tip, included</h3><p>No fumbling with roach material. Open, fill, twist, go.</p></div></div>
      <div class="citem"><span class="ck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></span><div><h3>Tobacco and nicotine free</h3><p>Just clean paper, shaped and ready when you are.</p></div></div>
      <div class="citem"><span class="ck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></span><div><h3>Signature resealable box</h3><p>A slide box in two finishes that protects every cone.</p></div></div>
      <div class="citem"><span class="ck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></span><div><h3>Designed in and for India</h3><p>Built for our market, made to a global standard.</p></div></div>
    </div>
  </div>
</section>

<!-- STORY -->
<section class="story">
  <div class="wrap sgrid">
    <div class="reveal">
      <div class="ey"><span class="ln"></span><span class="lab">Our story</span></div>
      <p class="quote">We got tired of cones that fell apart. So we built the <b>one we wanted.</b></p>
    </div>
    <div class="reveal">
      <p>Every cone on the shelf was either rough, chemical, or shaped like an accident. You paid for convenience and got a compromise.</p>
      <p>So we went the other way. <b>Organic, unbleached paper. A slow even burn. A perfect cone with a real tip.</b> Nothing added that does not belong in a clean roll.</p>
      <p>The name is a wink. The craft is dead serious. This is the cone you reach for first, then keep reaching for. <b>Welcome to the good stuff.</b></p>
    </div>
  </div>
</section>

<!-- SIGNUP -->
<section class="signup" id="store">
  <div class="wrap">
    <div class="reveal">
      <svg class="gmono" viewBox="0 0 100 100" style="color:var(--bone)"><use href="#monogram"/></svg>
      <h2>Find Roll Baby Roll near you.</h2>
      <p>We are rolling out to stores and delivery across India. Drop your email and we will tell you the moment we land in your area.</p>
      <div class="form">
        <input type="email" id="email" placeholder="you@email.com" aria-label="Email address">
        <button onclick="joinList()">Notify me</button>
      </div>
      <div class="form-note"><span class="lab">No spam, just the drop · 21+ only</span></div>
      <div class="form-ok" id="formok">You are on the list. Watch your inbox.</div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-brand">
        <div class="fb"><svg class="bmono" viewBox="0 0 100 100" style="color:var(--bone)"><use href="#monogram"/></svg><span class="wordmark">Roll Baby Roll</span></div>
        <p>Organic pre-rolled cones. Unbleached paper, slow burn, perfect shape. Made for people who do not settle.</p>
      </div>
      <div class="foot-cols">
        <div><h4>Product</h4><a href="#cones">The cones</a><a href="#packaging">Packaging</a><a href="#organic">Organic</a><a href="#standard">Our standard</a></div>
        <div><h4>Brand</h4><a href="#gallery">Gallery</a><a href="#store">Find a store</a><a href="#store">Stockist enquiries</a></div>
        <div><h4>Connect</h4><a href="#">Instagram</a><a href="#">WhatsApp</a><a href="#">Wholesale</a></div>
      </div>
    </div>
    <div class="foot-bot">
      <span class="lab">© 2026 Roll Baby Roll · An Instrek venture</span>
      <div style="display:flex;align-items:center;gap:16px"><span class="lab">Roll responsibly</span><span class="badge21">21+</span></div>
    </div>
  </div>
</footer>

<script>
function enter(){document.getElementById('gate').classList.add('hide');}
function leave(){window.location.href="https://www.google.com";}
function joinList(){var e=document.getElementById('email').value.trim();
  if(!e||e.indexOf('@')<1){document.getElementById('email').style.borderColor='#c46';return;}
  document.querySelector('.form').style.display='none';document.querySelector('.form-note').style.display='none';
  document.getElementById('formok').style.display='block';}
var io=new IntersectionObserver(function(en){en.forEach(function(x){if(x.isIntersecting){x.target.classList.add('in');io.unobserve(x.target);}});},{threshold:.12});
document.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
/* ember spine */
var lit=document.querySelector('.spine .lit'),emb=document.querySelector('.spine .ember');
function burn(){var h=document.documentElement,p=h.scrollTop/((h.scrollHeight-h.clientHeight)||1);p=Math.max(0,Math.min(1,p));
  lit.style.height=(p*100)+'%';emb.style.top=(p*100)+'%';}
window.addEventListener('scroll',burn,{passive:true});window.addEventListener('resize',burn);burn();
</script>
</body>
</html>
